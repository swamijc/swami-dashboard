{
  "manifest_version": 3,
  "name": "Swami Dashboard — Photon Session Refresh",
  "version": "1.1",
  "description": "Automatically refreshes Photon Timetracker and Photon Track sessions whenever you visit either site.",
  "permissions": [
    "cookies",
    "webRequest",
    "notifications"
  ],
  "host_permissions": [
    "https://timetracker.photon.com/*",
    "https://photontrack.photon.com/*",
    "http://localhost:3001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
